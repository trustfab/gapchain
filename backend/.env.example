# =========================================================================
# NPPXanhOrgMSP
# Tham gia: giaodich-channel
# =========================================================================
FABRIC_NPPXanhOrgMSP_CHANNELS=giaodich-channel
FABRIC_NPPXanhOrgMSP_CERT_PATH=../chain-setup/organizations/peerOrganizations/nppxanh.gapchain.vn/users/Admin@nppxanh.gapchain.vn/msp/signcerts/Admin@nppxanh.gapchain.vn-cert.pem
