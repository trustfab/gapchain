# Server
PORT=8080
GIN_MODE=debug

# Multi-Tenant Orgs (Phân tách theo dấu phẩy)
FABRIC_ORGS=PlatformOrgMSP,HTXNongSanOrgMSP,ChiCucBVTVOrgMSP,NPPXanhOrgMSP

# =========================================================================
# PlatformOrgMSP
# Tham gia cả 2 channel: nhatky-htx-channel, giaodich-channel
# =========================================================================
FABRIC_PlatformOrgMSP_CHANNELS=nhatky-htx-channel,giaodich-channel
FABRIC_PlatformOrgMSP_CERT_PATH=../chain-setup/organizations/peerOrganizations/platform.gapchain.vn/users/Admin@platform.gapchain.vn/msp/signcerts/Admin@platform.gapchain.vn-cert.pem
FABRIC_PlatformOrgMSP_KEY_PATH=../chain-setup/organizations/peerOrganizations/platform.gapchain.vn/users/Admin@platform.gapchain.vn/msp/keystore/
FABRIC_PlatformOrgMSP_PEER_ENDPOINT=localhost:7051
FABRIC_PlatformOrgMSP_TLS_CERT=../chain-setup/organizations/peerOrganizations/platform.gapchain.vn/peers/peer0.platform.gapchain.vn/tls/ca.crt
FABRIC_PlatformOrgMSP_GATEWAY_PEER=peer0.platform.gapchain.vn

# =========================================================================
# HTXNongSanOrgMSP
# Tham gia: nhatky-htx-channel
# =========================================================================
FABRIC_HTXNongSanOrgMSP_CHANNELS=nhatky-htx-channel
FABRIC_HTXNongSanOrgMSP_CERT_PATH=../chain-setup/organizations/peerOrganizations/htxnongsan.gapchain.vn/users/Admin@htxnongsan.gapchain.vn/msp/signcerts/Admin@htxnongsan.gapchain.vn-cert.pem
FABRIC_HTXNongSanOrgMSP_KEY_PATH=../chain-setup/organizations/peerOrganizations/htxnongsan.gapchain.vn/users/Admin@htxnongsan.gapchain.vn/msp/keystore/
FABRIC_HTXNongSanOrgMSP_PEER_ENDPOINT=localhost:9051
FABRIC_HTXNongSanOrgMSP_TLS_CERT=../chain-setup/organizations/peerOrganizations/htxnongsan.gapchain.vn/peers/peer0.htxnongsan.gapchain.vn/tls/ca.crt
FABRIC_HTXNongSanOrgMSP_GATEWAY_PEER=peer0.htxnongsan.gapchain.vn

# =========================================================================
# ChiCucBVTVOrgMSP
# Tham gia: nhatky-htx-channel
# =========================================================================
FABRIC_ChiCucBVTVOrgMSP_CHANNELS=nhatky-htx-channel
FABRIC_ChiCucBVTVOrgMSP_CERT_PATH=../chain-setup/organizations/peerOrganizations/chicucbvtv.gapchain.vn/users/Admin@chicucbvtv.gapchain.vn/msp/signcerts/Admin@chicucbvtv.gapchain.vn-cert.pem
